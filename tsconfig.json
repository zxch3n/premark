{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "paths": {
      "@pretext-md/parser": ["./packages/parser/src/index.ts"],
      "@pretext-md/layout": ["./packages/layout/src/index.ts"],
      "@pretext-md/highlight": ["./packages/highlight/src/index.ts"],
      "@pretext-md/html-renderer": ["./packages/html-renderer/src/index.ts"]
    },
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["apps", "packages", "scripts", "stories", ".storybook", "vitest.setup.ts"]
}
